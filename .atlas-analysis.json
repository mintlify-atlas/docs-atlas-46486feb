  "keyFeatures": [
    "Git-native agent definitions — version control, branching, diffing built in",
    "Framework-agnostic — export to Claude Code, OpenAI, CrewAI, Lyzr, GitHub Models, and more",
    "First-class compliance support — FINRA, Federal Reserve, SEC, CFPB regulatory requirements",
    "Segregation of duties — maker/checker/executor/auditor role separation with conflict enforcement",
    "Skills system — adopts the Agent Skills open standard with marketplace registry support",
    "Agent composition — extend parent agents, declare dependencies, define sub-agents",
    "CI/CD for agents — validate on every push via GitHub Actions",
    "Multi-adapter run command — clone any git repo and run the agent with the best adapter",
    "Compliance audit report — section-by-section regulatory checklist with pass/fail indicators",
    "MCP-compatible tool definitions stored in tools/*.yaml"
  ],
  "publicApiSurface": [
    "gitagent init [--template minimal|standard|full] [--dir]",
    "gitagent validate [--dir] [--compliance]",
    "gitagent info [--dir]",
    "gitagent export --format <system-prompt|claude-code|openai|crewai|openclaw|nanobot|lyzr|github> [--dir] [--output]",
    "gitagent import --from <claude|cursor|crewai> <path> [--dir]",
    "gitagent install [--dir]",
    "gitagent run [--repo|--dir] [--adapter] [--branch] [--prompt]",
    "gitagent audit [--dir]",
    "gitagent skills search|install|list|info",
    "gitagent lyzr create|update|info|run",
    "agent.yaml manifest schema (name, version, description, model, skills, tools, compliance, extends, dependencies)",
    "SOUL.md identity file",
    "RULES.md constraints file",
    "DUTIES.md segregation-of-duties policy file",
    "skills/*/SKILL.md Agent Skills standard format",
    "tools/*.yaml MCP-compatible tool definition schema",
    "hooks/hooks.yaml lifecycle event handler schema",
    "workflows/*.yaml multi-step procedure schema"
  ]
}
